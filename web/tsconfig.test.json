{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".test-dist",
    "rootDir": "."
  },
  "include": [
    "src/lib/auth.ts",
    "src/lib/access-control/**/*.ts",
    "src/lib/dashboard/**/*.ts",
    "src/lib/plugin-data/**/*.ts",
    "src/lib/plugin-configuration/**/*.ts",
    "src/lib/ribbon-layout/**/*.ts",
    "src/lib/runtime/**/*.ts",
    "test/**/*.test.ts"
  ]
}
