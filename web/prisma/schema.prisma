// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BaseRole {
  USER
  TESTER
  BOSS
}

enum CommandStage {
  RELEASED
  TESTING
  DEVELOPMENT
  DISABLED
}

enum UserCommandOverrideEffect {
  GRANT
  DENY
}

enum RibbonItemKind {
  push_button
  stack_2
  stack_3
  pulldown
  split_button
  separator
  slideout
}

model User {
  id                     String                 @id @default(uuid())
  username               String                 @unique
  isActive               Boolean                @default(true)
  baseRole               BaseRole               @default(USER)
  accessLevel            Int                    @default(1) // Legacy compatibility field: 1=User, 2=Tester, 3=Boss
  createdAt              DateTime               @default(now())
  lastLogin              DateTime?              // Legacy compatibility field
  lastLoginAt            DateTime?
  machineName            String?                // Legacy compatibility field
  lastMachineName        String?
  lastMachineFingerprint String?
  lastRevitVersion       String?
  usageLogs              UsageLog[]
  failedAttempts         FailedAttempt[]
  commandOverrides       UserCommandOverride[]
  securityEvents         SecurityEvent[]
  pluginSessionSnapshots PluginSessionSnapshot[]
}

model UsageLog {
  id           String                 @id @default(uuid())
  userId       String
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  pluginSlug   String                 @default("dokaflex")
  functionName String
  commandKey   String?
  snapshotId   String?
  snapshot     PluginSessionSnapshot? @relation(fields: [snapshotId], references: [snapshotId], onDelete: SetNull)
  timestamp    DateTime               @default(now())

  @@index([pluginSlug, commandKey])
}

model FailedAttempt {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username    String?  // Store username even if user is not in DB
  machineName String?
  reason      String?
  timestamp   DateTime @default(now())
}

model Command {
  id                  String                @id @default(uuid())
  pluginSlug          String                @default("dokaflex")
  commandKey          String
  displayName         String
  manifestTitle       String?
  iconCommandKey      String?
  stage               CommandStage          @default(RELEASED)
  isActive            Boolean               @default(true)
  category            String?
  description         String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  uniqueName          String                @unique // Legacy compatibility field
  descriptiveName     String
  requiredAccessLevel Int                   @default(1) // Legacy compatibility field: 1=User, 2=Tester, 3=Boss
  commandOverrides    UserCommandOverride[]

  @@unique([pluginSlug, commandKey])
}

model IconAsset {
  id          String   @id @default(uuid())
  pluginSlug  String
  iconKey     String
  contentType String?
  dataUri     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pluginSlug, iconKey])
  @@index([pluginSlug])
}

model RibbonTab {
  id         String   @id @default(uuid())
  pluginSlug String
  tabKey     String
  title      String
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([pluginSlug, tabKey])
  @@index([pluginSlug, order])
}

model RibbonPanel {
  id         String   @id @default(uuid())
  pluginSlug String
  panelKey   String
  tabKey     String
  title      String
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([pluginSlug, panelKey])
  @@index([pluginSlug, tabKey, order])
}

model RibbonItem {
  id             String   @id @default(uuid())
  pluginSlug     String
  itemKey        String
  panelKey       String
  order          Int
  kind           RibbonItemKind
  size           String?
  commandKey     String?
  iconCommandKey String?
  parentItemKey  String?
  title          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([pluginSlug, itemKey])
  @@index([pluginSlug, panelKey, order])
  @@index([pluginSlug, parentItemKey, order])
}

model RawUsageEvent {
  eventId            String                 @id
  pluginSlug         String
  commandKey         String
  username           String
  machineFingerprint String
  pluginVersion      String
  revitVersion       String
  occurredAtUtc      DateTime
  occurredOnDateUtc  DateTime
  snapshotId         String?
  snapshot           PluginSessionSnapshot? @relation(fields: [snapshotId], references: [snapshotId], onDelete: SetNull)
  createdAt          DateTime               @default(now())

  @@index([pluginSlug, commandKey, occurredAtUtc])
  @@index([pluginSlug, commandKey, occurredOnDateUtc])
  @@index([pluginSlug, username])
}

model UserCommandOverride {
  id        String                    @id @default(uuid())
  userId    String
  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  commandId String
  command   Command                   @relation(fields: [commandId], references: [id], onDelete: Cascade)
  effect    UserCommandOverrideEffect
  expiresAt DateTime?
  reason    String?
  createdAt DateTime                  @default(now())

  @@index([userId, commandId])
}

model SecurityEvent {
  id                 String   @id @default(uuid())
  userId             String?
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  pluginSlug         String?
  username           String?
  machineName        String?
  machineFingerprint String?
  eventType          String
  reason             String?
  details            String?
  createdAt          DateTime @default(now())

  @@index([createdAt])
  @@index([eventType])
}

model ApiKey {
  id         String   @id @default(uuid())
  name       String
  keyPrefix  String   @unique
  secretHash String
  scopes     String
  isActive   Boolean  @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
}

model PluginConfigurationState {
  pluginSlug               String   @id
  capabilityCatalogVersion Int      @default(0)
  ribbonLayoutVersion      Int      @default(0)
  configVersion            Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model PluginSessionSnapshot {
  snapshotId         String     @id @default(uuid())
  userId             String
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pluginSlug         String
  pluginVersion      String?
  machineFingerprint String
  machineName        String
  revitVersion       String
  policyVersion      Int
  issuedAtUtc        DateTime
  refreshAfterUtc    DateTime
  graceUntilUtc      DateTime
  revokedAtUtc       DateTime?
  allowedCommandKeys String?
  createdAt          DateTime   @default(now())
  usageLogs          UsageLog[]
  rawUsageEvents     RawUsageEvent[]

  @@index([userId, pluginSlug])
  @@index([machineFingerprint])
}
